import os
from ament_index_python.packages import get_package_share_directory
from launch import LaunchDescription
from launch_ros.action import Node

def generate_launch_description():
	pkg_name = 'so101_kinematics'
	pkg_share = get_packageshare_directory(pkg_name)
	urdf_file = os.path.join(pkg_share, 'urdf', 'LeRobotSO101.urdf')
	with open (urdf_file, 'r') as infp:
		robot_desc = infp.read()
	rsp_node = Node(
        package='robot_state_publisher',
        executable='robot_state_publisher',
        output='screen',
        parameters=[{'robot_description': robot_desc}]
    )

    # 2. Node: joint_state_publisher_gui (Csúszkák a kézi teszteléshez)
    jsp_gui_node = Node(
        package='joint_state_publisher_gui',
        executable='joint_state_publisher_gui',
        output='screen'
    )

    # 3. Node: RViz2 (A 3D vizualizáció)
    rviz_node = Node(
        package='rviz2',
        executable='rviz2',
      	  output='screen'
    )

    return LaunchDescription([
        rsp_node,
        jsp_gui_node,
        rviz_node
    ])	
